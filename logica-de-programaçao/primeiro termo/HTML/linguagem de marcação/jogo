    // FUNÇÃO QUE ESTAVA FALTANDO
    function resetPlayer() {
        player.x = 50;
        player.y = 100;
        player.vx = 0;
        player.vy = 0;
        player.grounded = false;
    }
    function update() {
        const level = levels[currentLevel];
        player.vx = 0;
        if (keys["ArrowLeft"]) player.vx = -player.speed;
        if (keys["ArrowRight"]) player.vx = player.speed;
        if (keys["Space"] && player.grounded) {
            player.vy = player.jump;
            player.grounded = false;
        }
        player.vy += gravity;
        player.x += player.vx;
        player.y += player.vy;
        player.grounded = false;
        // colisão plataformas
        for (const p of level.platforms) {
            if (
                player.x < p.x + p.width &&
                player.x + player.width > p.x &&
                player.y < p.y + p.height &&
                player.y + player.height > p.y
            ) {
                if (player.vy > 0) {
                    player.y = p.y - player.height;
                    player.vy = 0;
                    player.grounded = true;
                }
            }
        }
        // espinhos
        for (const spike of level.spikes) {
            if (
                player.x < spike.x + spike.width &&
                player.x + player.width > spike.x &&
                player.y < spike.y + spike.height &&
                player.y + player.height > spike.y
            ) {
                resetPlayer();
            }
        }
        // inimigos
        for (const enemy of level.enemies) {
            enemy.x += enemy.speed;
            if (
                enemy.x <= enemy.minX ||
                enemy.x + enemy.width >= enemy.maxX
            ) {
                enemy.speed *= -1;
            }
            if (
                player.x < enemy.x + enemy.width &&
                player.x + player.width > enemy.x &&
                player.y < enemy.y + enemy.height &&
                player.y + player.height > enemy.y
            ) {
                resetPlayer();
            }
        }
        // cair do mapa
        if (player.y > canvas.height + 100) {
            resetPlayer();
        }
        // limites
        if (player.x < 0) player.x = 0;
        if (player.x + player.width > canvas.width) {
            player.x = canvas.width - player.width;
        }
        // chegada
        const goal = level.goal;
        if (
            player.x < goal.x + goal.width &&
            player.x + player.width > goal.x &&
            player.y < goal.y + goal.height &&
            player.y + player.height > goal.y
        ) {
            currentLevel++;
            if (currentLevel >= levels.length) {
                setTimeout(() => {
                    alert("🏆 PARABÉNS! VOCÊ ZEROU O JOGO!");
                }, 100);
                currentLevel = 0;
            }
            resetPlayer();
        }
    }
    function draw() {
        const level = levels[currentLevel];
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        // plataformas
        ctx.fillStyle = "#228B22";
        for (const p of level.platforms) {
            ctx.fillRect(p.x, p.y, p.width, p.height);
        }
        // espinhos
        ctx.fillStyle = "red";
        for (const spike of level.spikes) {
            ctx.beginPath();
            ctx.moveTo(spike.x, spike.y + spike.height);
            ctx.lineTo(spike.x + spike.width / 2, spike.y);
            ctx.lineTo(spike.x + spike.width, spike.y + spike.height);
            ctx.fill();
        }
        // inimigos
        ctx.fillStyle = "purple";
        for (const enemy of level.enemies) {
            ctx.fillRect(
                enemy.x,
                enemy.y,
                enemy.width,
                enemy.height
            );
        }
        // bandeira
        ctx.fillStyle = "gold";
        ctx.fillRect(
            level.goal.x,
            level.goal.y,
            level.goal.width,
            level.goal.height
        );
        // jogador
        ctx.fillStyle = "#ff4444";
        ctx.fillRect(
            player.x,
            player.y,
            player.width,
            player.height
        );
        // interface - CORRIGIDO PARA MOSTRAR 9 FASES
        ctx.fillStyle = "black";
        ctx.font = "22px Arial";
        ctx.fillText(
            "Fase " + (currentLevel + 1) + " / " + levels.length,
            20,
            30
        );
        ctx.font = "16px Arial";
        ctx.fillText(
            "← → mover | Espaço pular",
            20,
            55
        );
        ctx.fillText(
            "Pegue a bandeira dourada",
            20,
            80
        );
        ctx.fillStyle = "purple";
        ctx.fillText("■ Inimigo", 20, 110);
        ctx.fillStyle = "red";
        ctx.fillText("▲ Espinho", 20, 135);
    }
    function gameLoop() {
        update();
        draw();
        requestAnimationFrame(gameLoop);
    }
    gameLoop();
</script>
